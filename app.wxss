page {
  background: #f5f6fa;
  color: #1a1a1f;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 26rpx;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

button {
  padding: 0;
  margin: 0;
  border: 0;
  border-radius: 0;
  background: transparent;
  line-height: 1.2;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 28rpx 24rpx 48rpx;
}

.eyebrow {
  color: #a0a0b0;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0;
}

.title {
  color: #111111;
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.15;
}

.section-title {
  color: #111111;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.25;
}

.muted {
  color: #888899;
}

.card {
  background: #ffffff;
  border: 1rpx solid #ebebf0;
  border-radius: 14rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.surface-soft {
  background: #f5f5f8;
  border: 1rpx solid #ebebf0;
}

.primary-button {
  min-height: 84rpx;
  padding: 0 32rpx;
  border-radius: 12rpx;
  background: #111111;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 650;
}

.primary-button:active {
  background: #333333;
}

.secondary-button {
  min-height: 76rpx;
  padding: 0 26rpx;
  border: 1rpx solid #e0e0e8;
  border-radius: 12rpx;
  color: #555566;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
}

.secondary-button:active {
  background: #f5f5f8;
}

.pill {
  display: inline-flex;
  align-items: center;
  min-height: 40rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #f0f4ff;
  color: #2563eb;
  font-size: 22rpx;
  font-weight: 600;
}

.risk-low {
  background: rgba(22, 163, 74, 0.08);
  color: #16a34a;
}

.risk-mid {
  background: rgba(217, 119, 6, 0.08);
  color: #d97706;
}

.risk-high {
  background: rgba(220, 38, 38, 0.08);
  color: #dc2626;
}

.divider {
  height: 1rpx;
  background: #f0f0f5;
}

.warning-panel {
  padding: 20rpx 22rpx;
  border: 1rpx solid rgba(217, 119, 6, 0.16);
  border-left: 6rpx solid #d97706;
  border-radius: 12rpx;
  background: rgba(217, 119, 6, 0.08);
  color: #8a4b05;
  line-height: 1.5;
}

.danger-panel {
  padding: 20rpx 22rpx;
  border: 1rpx solid rgba(220, 38, 38, 0.16);
  border-left: 6rpx solid #dc2626;
  border-radius: 12rpx;
  background: rgba(220, 38, 38, 0.08);
  color: #991b1b;
  line-height: 1.5;
}
