.list-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.small-button {
  min-width: 120rpx;
  min-height: 68rpx;
  padding: 0 20rpx;
}

.case-row {
  padding: 24rpx;
  margin-bottom: 14rpx;
}

.row-top {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.row-next {
  margin: 24rpx 0 18rpx;
  color: #111111;
  font-weight: 700;
}

.progress-track {
  height: 10rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #ebebf0;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: #2563eb;
}
