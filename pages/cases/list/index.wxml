<view class="page">
  <view class="list-header">
    <view>
      <text class="eyebrow">案件</text>
      <view class="title">我的处理进度</view>
    </view>
    <button class="secondary-button small-button" bindtap="createCase">新建</button>
  </view>

  <view wx:for="{{cases}}" wx:key="id" class="card case-row" bindtap="openCase">
    <view class="row-top">
      <view>
        <view class="section-title">{{item.title}}</view>
        <text class="muted">{{item.plate}}</text>
      </view>
      <text class="pill risk-mid">{{item.status}}</text>
    </view>
    <view class="row-next">下一步：{{item.nextAction}}</view>
    <view class="progress-track">
      <view class="progress-fill" style="width: {{item.progress}}%;"></view>
    </view>
  </view>
</view>

