<view class="page">
  <view wx:if="{{loading}}" class="card state-card">正在加载案件看板...</view>
  <view wx:elif="{{error}}" class="danger-panel state-card">{{error}}</view>

  <block wx:else>
  <view class="case-hero">
    <text class="eyebrow">案件看板</text>
    <view class="title">{{currentCase.title}}</view>
    <view class="meta-line">
      <text>{{currentCase.plate}}</text>
      <text class="pill risk-mid">风险 {{currentCase.riskLevel}}</text>
    </view>
  </view>

  <view class="card summary-card">
    <view>
      <view class="summary-label">当前阶段</view>
      <view class="summary-value">{{currentCase.currentStage}}</view>
    </view>
    <view>
      <view class="summary-label">材料完成度</view>
      <view class="summary-value">{{currentCase.materialCompleteness}}%</view>
    </view>
  </view>

  <view class="card stage-card">
    <view wx:for="{{stages}}" wx:key="label" class="stage-item {{item.status}}">
      <view class="stage-dot"></view>
      <text>{{item.shortLabel}}</text>
    </view>
  </view>

  <view class="card next-card">
    <text class="muted">下一步</text>
    <view class="next-action">{{currentCase.nextAction}}</view>
    <text class="muted">{{currentCase.nextActionTime}}</text>
    <button class="primary-button" bindtap="goMaterials">上传缺失材料</button>
  </view>

  <view class="warning-panel risk-note">
    {{currentCase.highRiskReason}}
    <button class="review-link" bindtap="goCheckout">人工复核</button>
  </view>

  <view class="card progress-card">
    <view class="section-title">处理进度</view>
    <view wx:for="{{tasks}}" wx:key="title" class="task-row">
      <text>{{item.title}}</text>
      <text class="task-status">{{item.status}}</text>
    </view>
  </view>

  <view class="card documents-card">
    <view class="section-title">文书生成状态</view>
    <view wx:for="{{documentDrafts}}" wx:key="name" class="doc-row">
      <text>{{item.name}}</text>
      <text class="muted">{{item.status}}</text>
    </view>
  </view>

  <view class="action-stack">
    <button class="secondary-button" bindtap="goReport">查看赔偿测算</button>
    <button class="secondary-button" bindtap="goDocuments">查看文书草稿</button>
    <button class="primary-button" bindtap="goDocuments">生成处理材料</button>
  </view>
  </block>
</view>
