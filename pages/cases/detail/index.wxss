.case-hero {
  margin-bottom: 28rpx;
}

.meta-line {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  margin-top: 22rpx;
  color: #888899;
}

.stage-card {
  padding: 20rpx 12rpx;
  margin-bottom: 22rpx;
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 8rpx;
}

.stage-item {
  color: #a0a0b0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.stage-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #d9dce5;
}

.stage-item.done,
.stage-item.active,
.stage-item.ready {
  color: #2563eb;
}

.stage-item.done .stage-dot,
.stage-item.active .stage-dot,
.stage-item.ready .stage-dot {
  background: #2563eb;
}

.stage-item.active .stage-dot {
  box-shadow: 0 0 0 8rpx rgba(37, 99, 235, 0.12);
}

.next-card,
.progress-card,
.documents-card {
  padding: 28rpx;
  margin-bottom: 22rpx;
}

.risk-note {
  margin-bottom: 22rpx;
}

.review-link {
  display: inline-flex;
  margin-left: 14rpx;
  color: #2563eb;
  font-weight: 800;
  font-size: 26rpx;
  vertical-align: baseline;
}

.next-action {
  margin: 10rpx 0 20rpx;
  color: #111111;
  font-size: 34rpx;
  font-weight: 760;
}

.task-row {
  min-height: 76rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #f0f0f5;
}

.task-row:last-child {
  border-bottom: 0;
}

.task-status {
  color: #2563eb;
  font-weight: 700;
}

.doc-row {
  min-height: 74rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #f0f0f5;
}

.doc-row:last-child {
  border-bottom: 0;
}

.action-stack {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}
