.home-page {
  padding-top: 40rpx;
}

.hero {
  display: flex;
  justify-content: space-between;
  gap: 32rpx;
  align-items: flex-start;
  margin-bottom: 34rpx;
}

.hero-mark {
  width: 104rpx;
  height: 104rpx;
  border: 1rpx solid rgba(18, 61, 54, 0.18);
  border-radius: 16rpx;
  background: #123d36;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 800;
  box-shadow: 0 24rpx 56rpx rgba(18, 61, 54, 0.22);
}

.start-button {
  margin-bottom: 24rpx;
}

.current-card {
  padding: 28rpx;
}

.card-top {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  align-items: flex-start;
}

.case-plate {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
}

.next-box {
  margin: 30rpx 0 22rpx;
  padding: 24rpx;
  border-radius: 14rpx;
  background: #f4f8f6;
}

.next-action {
  margin: 8rpx 0;
  color: #123d36;
  font-size: 34rpx;
  font-weight: 800;
}

.progress-track {
  height: 12rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #e1e7e4;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: #123d36;
}

.quick-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 24rpx;
}

.quick-item {
  min-height: 150rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  font-weight: 760;
}

.quick-icon {
  width: 42rpx;
  height: 42rpx;
  border-radius: 12rpx;
  background: #edf3f1;
  color: #123d36;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
}

.notice {
  margin-top: 28rpx;
  padding: 22rpx 24rpx;
  border-left: 6rpx solid #b7791f;
  border-radius: 10rpx;
  background: #fff7e8;
  color: #6b520f;
  line-height: 1.5;
}

