.home-page {
  padding-top: 40rpx;
}

.hero {
  display: flex;
  justify-content: space-between;
  gap: 32rpx;
  align-items: flex-start;
  margin-bottom: 34rpx;
}

.subcopy {
  margin: -18rpx 0 28rpx;
  color: #6b7471;
  line-height: 1.55;
}

.hero-mark {
  width: 104rpx;
  height: 104rpx;
  border: 1rpx solid rgba(18, 61, 54, 0.18);
  border-radius: 16rpx;
  background: #123d36;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 800;
  box-shadow: 0 24rpx 56rpx rgba(18, 61, 54, 0.22);
}

.start-button {
  margin-bottom: 24rpx;
}

.action-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.action-card {
  min-height: 176rpx;
  padding: 22rpx;
  border: 1rpx solid #e1e7e4;
  border-radius: 16rpx;
  background: #ffffff;
  color: #18211f;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  text-align: left;
  box-shadow: 0 14rpx 36rpx rgba(18, 61, 54, 0.05);
}

.action-primary {
  background: #123d36;
  color: #ffffff;
  border-color: #123d36;
}

.action-index {
  color: #5e7f78;
  font-size: 22rpx;
  font-weight: 800;
}

.action-primary .action-index,
.action-primary .action-desc {
  color: rgba(255, 255, 255, 0.72);
}

.action-title {
  font-size: 30rpx;
  font-weight: 820;
}

.action-desc {
  margin-top: 8rpx;
  color: #6b7471;
  font-size: 22rpx;
  line-height: 1.35;
}

.current-card {
  padding: 28rpx;
}

.card-top {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  align-items: flex-start;
}

.case-plate {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
}

.stage-rail {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 8rpx;
  margin-top: 30rpx;
  padding: 22rpx 12rpx;
  border-radius: 14rpx;
  background: #f7faf9;
}

.stage-item {
  min-width: 0;
  color: #8a9692;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.stage-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #d4ded9;
}

.stage-item.done,
.stage-item.active,
.stage-item.ready {
  color: #123d36;
}

.stage-item.done .stage-dot,
.stage-item.active .stage-dot,
.stage-item.ready .stage-dot {
  background: #123d36;
}

.stage-item.active .stage-dot {
  box-shadow: 0 0 0 8rpx rgba(18, 61, 54, 0.13);
}

.next-box {
  margin: 30rpx 0 22rpx;
  padding: 24rpx;
  border-radius: 14rpx;
  background: #f4f8f6;
}

.next-action {
  margin: 8rpx 0;
  color: #123d36;
  font-size: 34rpx;
  font-weight: 800;
}

.next-meta {
  display: flex;
  justify-content: space-between;
  gap: 14rpx;
  align-items: center;
}

.progress-track {
  height: 12rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #e1e7e4;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: #123d36;
}

.notice {
  margin-top: 28rpx;
}
