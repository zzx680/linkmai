.home-page {
  padding-top: 24rpx;
}

.topbar {
  height: 64rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.brand {
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: #111111;
  font-size: 28rpx;
  font-weight: 760;
}

.brand-mark {
  width: 44rpx;
  height: 44rpx;
  border-radius: 10rpx;
  background: #111111;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 800;
}

.top-status {
  color: #a0a0b0;
  font-size: 22rpx;
  font-weight: 600;
}

.hero {
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  align-items: center;
  margin-bottom: 20rpx;
}

.subcopy {
  margin-top: 12rpx;
  color: #888899;
  font-size: 24rpx;
  line-height: 1.5;
}

.hero-button {
  min-width: 176rpx;
  min-height: 72rpx;
  flex-shrink: 0;
}

.action-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.action-card {
  min-height: 160rpx;
  padding: 22rpx;
  border: 1rpx solid #ebebf0;
  border-radius: 14rpx;
  background: #ffffff;
  color: #111111;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  text-align: left;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.action-primary {
  background: #111111;
  color: #ffffff;
  border-color: #111111;
}

.action-index {
  color: #a0a0b0;
  font-size: 22rpx;
  font-weight: 800;
}

.action-primary .action-index,
.action-primary .action-desc {
  color: rgba(255, 255, 255, 0.72);
}

.action-title {
  font-size: 28rpx;
  font-weight: 760;
}

.action-desc {
  margin-top: 8rpx;
  color: #888899;
  font-size: 22rpx;
  line-height: 1.35;
}

.current-card {
  padding: 28rpx;
}

.card-top {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  align-items: flex-start;
}

.case-plate {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
}

.stage-rail {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 8rpx;
  margin-top: 26rpx;
  padding: 20rpx 12rpx;
  border-radius: 12rpx;
  background: #f8f8fb;
}

.stage-item {
  min-width: 0;
  color: #a0a0b0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.stage-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #d9dce5;
}

.stage-item.done,
.stage-item.active,
.stage-item.ready {
  color: #2563eb;
}

.stage-item.done .stage-dot,
.stage-item.active .stage-dot,
.stage-item.ready .stage-dot {
  background: #2563eb;
}

.stage-item.active .stage-dot {
  box-shadow: 0 0 0 8rpx rgba(37, 99, 235, 0.12);
}

.next-box {
  margin: 24rpx 0 22rpx;
  padding: 24rpx;
  border: 1rpx solid #f0f0f5;
  border-radius: 12rpx;
  background: #fafafa;
}

.box-label {
  color: #a0a0b0;
  font-size: 22rpx;
  font-weight: 700;
}

.next-action {
  margin: 8rpx 0;
  color: #111111;
  font-size: 32rpx;
  font-weight: 760;
}

.next-meta {
  display: flex;
  justify-content: space-between;
  gap: 14rpx;
  align-items: center;
}

.progress-track {
  height: 10rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #ebebf0;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: #2563eb;
}

.notice {
  margin-top: 28rpx;
}
