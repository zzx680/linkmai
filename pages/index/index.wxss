.home-page {
  padding-top: 40rpx;
}

.hero {
  display: flex;
  justify-content: space-between;
  gap: 32rpx;
  align-items: flex-start;
  margin-bottom: 34rpx;
}

.subcopy {
  margin: -18rpx 0 28rpx;
  color: #6b7471;
  line-height: 1.55;
}

.hero-mark {
  width: 104rpx;
  height: 104rpx;
  border: 1rpx solid rgba(18, 61, 54, 0.18);
  border-radius: 16rpx;
  background: #123d36;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 800;
  box-shadow: 0 24rpx 56rpx rgba(18, 61, 54, 0.22);
}

.start-button {
  margin-bottom: 24rpx;
}

.current-card {
  padding: 28rpx;
}

.card-top {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  align-items: flex-start;
}

.case-plate {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
}

.stage-rail {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 8rpx;
  margin-top: 30rpx;
  padding: 22rpx 12rpx;
  border-radius: 14rpx;
  background: #f7faf9;
}

.stage-item {
  min-width: 0;
  color: #8a9692;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.stage-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #d4ded9;
}

.stage-item.done,
.stage-item.active,
.stage-item.ready {
  color: #123d36;
}

.stage-item.done .stage-dot,
.stage-item.active .stage-dot,
.stage-item.ready .stage-dot {
  background: #123d36;
}

.stage-item.active .stage-dot {
  box-shadow: 0 0 0 8rpx rgba(18, 61, 54, 0.13);
}

.next-box {
  margin: 30rpx 0 22rpx;
  padding: 24rpx;
  border-radius: 14rpx;
  background: #f4f8f6;
}

.next-action {
  margin: 8rpx 0;
  color: #123d36;
  font-size: 34rpx;
  font-weight: 800;
}

.next-meta {
  display: flex;
  justify-content: space-between;
  gap: 14rpx;
  align-items: center;
}

.progress-track {
  height: 12rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #e1e7e4;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: #123d36;
}

.entitlements {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
  flex-wrap: wrap;
}

.mini-tag {
  padding: 8rpx 12rpx;
  border-radius: 10rpx;
  background: #edf3f1;
  color: #123d36;
  font-size: 22rpx;
  font-weight: 700;
}

.quick-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 24rpx;
}

.quick-item {
  min-height: 150rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  font-weight: 760;
}

.quick-icon {
  width: 42rpx;
  height: 42rpx;
  border-radius: 12rpx;
  background: #edf3f1;
  color: #123d36;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
}

.notice {
  margin-top: 28rpx;
}
