.intake-page {
  display: flex;
  flex-direction: column;
}

.progress-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
}

.intake-title {
  margin-top: 8rpx;
  color: #111111;
  font-size: 36rpx;
  font-weight: 760;
  line-height: 1.18;
}

.bar {
  height: 10rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #ebebf0;
  margin-bottom: 28rpx;
}

.bar-fill {
  height: 100%;
  border-radius: 999rpx;
  background: #2563eb;
}

.question-card {
  padding: 34rpx 28rpx;
}

.question-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.save-button {
  color: #2563eb;
  font-size: 24rpx;
  font-weight: 700;
}

.hint {
  margin-top: 14rpx;
  color: #888899;
  line-height: 1.5;
}

.why-box {
  margin-top: 22rpx;
  padding: 20rpx 22rpx;
  border: 1rpx solid #f0f0f5;
  border-radius: 12rpx;
  background: #fafafa;
  color: #666677;
  font-size: 24rpx;
  line-height: 1.45;
}

.option-list {
  margin-top: 34rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.option {
  min-height: 92rpx;
  padding: 0 24rpx;
  border: 1rpx solid #e0e0e8;
  border-radius: 12rpx;
  background: #ffffff;
  color: #111111;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  font-size: 28rpx;
  font-weight: 680;
  text-align: left;
  gap: 16rpx;
}

.option-active {
  border-color: #9dbfff;
  background: #f0f4ff;
  color: #2563eb;
}

.option-dot {
  width: 20rpx;
  height: 20rpx;
  border: 2rpx solid #c8cbd5;
  border-radius: 50%;
}

.option-active .option-dot {
  border-color: #2563eb;
  background: #2563eb;
  box-shadow: 0 0 0 6rpx rgba(37, 99, 235, 0.12);
}

.answer-panel {
  margin-top: 20rpx;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12rpx;
}

.answer-title {
  color: #888899;
  font-size: 24rpx;
}

.answer-chip {
  padding: 10rpx 14rpx;
  border-radius: 12rpx;
  background: #f0f4ff;
  color: #2563eb;
  font-size: 22rpx;
  font-weight: 700;
}

.risk-preview {
  margin-top: 20rpx;
}

.bottom-actions {
  margin-top: auto;
  padding-top: 34rpx;
  display: grid;
  grid-template-columns: 1fr 1.4fr;
  gap: 18rpx;
}
