<view class="page intake-page">
  <view class="progress-head">
    <view>
      <text class="eyebrow">事故问诊</text>
      <view class="intake-title">一步只确认一件事</view>
    </view>
    <text class="muted">{{step + 1}} / {{questions.length}}</text>
  </view>

  <view class="bar">
    <view class="bar-fill" style="width: {{(step + 1) * 100 / questions.length}}%;"></view>
  </view>

  <view class="question-card card">
    <view class="question-meta">
      <text class="pill">{{questions[step].type}}</text>
      <button class="save-button" disabled="{{saving}}" bindtap="saveDraft">
        {{saving ? '保存中' : '保存草稿'}}
      </button>
    </view>
    <view class="section-title">{{questions[step].title}}</view>
    <view class="hint">{{questions[step].hint}}</view>
    <view class="why-box">{{questions[step].why}}</view>

    <view class="option-list">
      <button
        wx:for="{{questions[step].options}}"
        wx:key="*this"
        class="option {{answers[step] === item ? 'option-active' : ''}}"
        data-value="{{item}}"
        bindtap="choose"
      >
        <view class="option-dot"></view>
        {{item}}
      </button>
    </view>
  </view>

  <view class="answer-panel" wx:if="{{answers.length}}">
    <view class="answer-title">已确认</view>
    <view wx:for="{{answers}}" wx:key="*this" wx:if="{{item}}" class="answer-chip">
      {{item}}
    </view>
  </view>

  <view class="danger-panel risk-preview" wx:if="{{riskOptions.indexOf(answers[step]) !== -1}}">
    这个选项可能触发人工复核。系统会先帮你整理材料，但不会直接给确定性赔偿结论。
  </view>

  <view class="bottom-actions">
    <button class="secondary-button" disabled="{{step === 0}}" bindtap="prev">上一步</button>
    <button class="primary-button" disabled="{{!answers[step]}}" bindtap="next">
      {{step === questions.length - 1 ? '生成案件看板' : '继续'}}
    </button>
  </view>
</view>
