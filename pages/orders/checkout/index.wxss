.checkout-head {
  margin-bottom: 28rpx;
}

.copy {
  margin-top: 14rpx;
  line-height: 1.5;
}

.product-card {
  min-height: 150rpx;
  margin-bottom: 18rpx;
  padding: 26rpx;
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  border-color: #e1e7e4;
}

.product-card.selected {
  border-color: #123d36;
  background: #f2f7f5;
}

.badge-line {
  margin-bottom: 10rpx;
}

.product-name {
  font-size: 32rpx;
  font-weight: 800;
}

.included {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
  margin-top: 18rpx;
}

.mini-tag {
  padding: 8rpx 12rpx;
  border-radius: 10rpx;
  background: #edf3f1;
  color: #123d36;
  font-size: 22rpx;
  font-weight: 700;
}

.product-desc {
  margin-top: 10rpx;
  line-height: 1.45;
  font-size: 24rpx;
}

.product-price {
  min-width: 120rpx;
  color: #123d36;
  font-size: 32rpx;
  font-weight: 860;
  text-align: right;
}

.limit-card {
  margin: 28rpx 0;
  padding: 26rpx;
}

.limit-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 20rpx;
}

.limit-label {
  color: #123d36;
  font-size: 24rpx;
  font-weight: 800;
}

.limit-line {
  margin-top: 8rpx;
  color: #6b7471;
  line-height: 1.45;
}

.pay-warning {
  margin-bottom: 24rpx;
}
