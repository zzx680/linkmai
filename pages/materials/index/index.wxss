.material-head {
  margin-bottom: 24rpx;
}

.copy {
  margin-top: 14rpx;
  line-height: 1.5;
}

.group {
  margin-bottom: 24rpx;
}

.group-title {
  margin-bottom: 12rpx;
  color: #888899;
  font-size: 24rpx;
}

.material-card {
  min-height: 132rpx;
  margin-bottom: 12rpx;
  padding: 22rpx;
  display: flex;
  justify-content: space-between;
  gap: 22rpx;
  position: relative;
}

.material-card::before {
  content: "";
  width: 4rpx;
  height: 64rpx;
  border-radius: 999rpx;
  background: #2563eb;
  position: absolute;
  left: 0;
  top: 26rpx;
}

.material-info {
  flex: 1;
}

.material-name {
  color: #111111;
  font-size: 28rpx;
  font-weight: 700;
}

.purpose {
  margin-top: 10rpx;
  line-height: 1.45;
  font-size: 24rpx;
}

.material-side {
  width: 150rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: space-between;
}

.upload-button {
  color: #2563eb;
  font-weight: 700;
  font-size: 24rpx;
}

.upload-button[disabled] {
  color: #a0a0b0;
}

.danger-panel {
  margin-top: 10rpx;
}
