.login-page {
  display: flex;
  flex-direction: column;
}

.login-hero {
  margin-bottom: 30rpx;
}

.login-mark {
  width: 112rpx;
  height: 112rpx;
  margin-bottom: 26rpx;
  border-radius: 16rpx;
  background: #111111;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 860;
  box-shadow: 0 10rpx 28rpx rgba(0, 0, 0, 0.12);
}

.copy {
  margin-top: 18rpx;
  line-height: 1.55;
}

.auth-card {
  padding: 28rpx;
}

.auth-row {
  min-height: 72rpx;
  display: flex;
  align-items: center;
  color: #888899;
  border-bottom: 1rpx solid #f0f0f5;
}

.auth-row:last-child {
  border-bottom: 0;
}

.agree-row {
  margin: auto 0 28rpx;
  padding-top: 42rpx;
  display: flex;
  gap: 16rpx;
  color: #888899;
  line-height: 1.55;
  font-size: 24rpx;
}

.check {
  flex: 0 0 auto;
  width: 34rpx;
  height: 34rpx;
  margin-top: 4rpx;
  border: 2rpx solid #c8cbd5;
  border-radius: 8rpx;
}

.checked {
  border-color: #2563eb;
  background: #2563eb;
}

.link {
  color: #2563eb;
  font-weight: 760;
}
