.doc-head {
  margin-bottom: 28rpx;
}

.copy {
  margin-top: 14rpx;
  line-height: 1.55;
}

.delivery-card {
  margin-bottom: 22rpx;
  padding: 26rpx;
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  align-items: center;
}

.delivery-label {
  color: #888899;
  font-size: 24rpx;
}

.delivery-value {
  margin-top: 8rpx;
  color: #111111;
  font-size: 30rpx;
  font-weight: 760;
}

.review-button {
  min-width: 176rpx;
  min-height: 72rpx;
}

.doc-card {
  min-height: 146rpx;
  margin-bottom: 14rpx;
  padding: 24rpx;
  display: flex;
  justify-content: space-between;
  gap: 22rpx;
}

.doc-name {
  color: #111111;
  font-size: 30rpx;
  font-weight: 760;
}

.doc-desc {
  margin-top: 10rpx;
  line-height: 1.45;
  font-size: 24rpx;
}

.material-state {
  margin-top: 14rpx;
  color: #2563eb;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.35;
}

.doc-side {
  width: 150rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: space-between;
}

.upload-button {
  color: #2563eb;
  font-weight: 700;
  font-size: 24rpx;
}
