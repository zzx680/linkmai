.report-hero {
  margin-bottom: 24rpx;
}

.report-title {
  margin-top: 10rpx;
  color: #111111;
  font-size: 34rpx;
  font-weight: 760;
}

.amount {
  margin: 14rpx 0;
  color: #111111;
  font-size: 52rpx;
  font-weight: 800;
}

.confidence-card {
  margin-bottom: 22rpx;
  padding: 26rpx;
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  align-items: center;
}

.confidence-label {
  color: #888899;
  font-size: 24rpx;
}

.confidence-value {
  margin-top: 6rpx;
  color: #2563eb;
  font-size: 42rpx;
  font-weight: 800;
}

.confidence-copy {
  flex: 1;
  color: #888899;
  line-height: 1.45;
  text-align: right;
}

.item-list {
  margin-bottom: 26rpx;
  padding: 8rpx 24rpx;
}

.list-title {
  padding: 24rpx 0 6rpx;
  color: #111111;
  font-size: 30rpx;
  font-weight: 700;
}

.claim-row {
  min-height: 132rpx;
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f5;
}

.claim-row:last-child {
  border-bottom: 0;
}

.claim-name {
  color: #111111;
  font-size: 28rpx;
  font-weight: 700;
}

.claim-detail {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.45;
}

.basis {
  margin-top: 12rpx;
  color: #2563eb;
  font-size: 22rpx;
  line-height: 1.4;
}

.claim-side {
  min-width: 170rpx;
  text-align: right;
}

.claim-amount {
  display: block;
  color: #111111;
  font-size: 28rpx;
  font-weight: 760;
}

.evidence {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
}

.missing-card {
  margin-bottom: 24rpx;
  padding: 26rpx;
}

.missing-row {
  min-height: 86rpx;
  padding: 16rpx 0;
  display: grid;
  grid-template-columns: 150rpx 1fr;
  gap: 16rpx;
  align-items: flex-start;
  border-bottom: 1rpx solid #f0f0f5;
  line-height: 1.4;
}

.missing-row:last-child {
  border-bottom: 0;
}

.missing-name {
  color: #111111;
  font-weight: 700;
}

.missing-impact {
  color: #888899;
}

.action-stack {
  display: grid;
  grid-template-columns: 1fr 1.35fr;
  gap: 16rpx;
}
