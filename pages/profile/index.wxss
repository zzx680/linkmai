.profile-card {
  padding: 28rpx;
  display: flex;
  align-items: center;
  gap: 22rpx;
  margin-bottom: 24rpx;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 16rpx;
  background: #123d36;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 800;
}

.row-card {
  padding: 0 24rpx;
}

.profile-row {
  min-height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #edf1ef;
}

.profile-row:last-child {
  border-bottom: 0;
}

