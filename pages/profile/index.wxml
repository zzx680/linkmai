<view class="page">
  <view class="profile-card card">
    <view class="avatar">L</view>
    <view>
      <view class="section-title">微信用户</view>
      <text class="muted">手机号待绑定</text>
    </view>
  </view>

  <view class="card row-card">
    <view
      wx:for="{{rows}}"
      wx:key="label"
      class="profile-row"
      data-path="{{item.path}}"
      bindtap="openRow"
    >
      <text>{{item.label}}</text>
      <text class="muted">{{item.value || '查看'}}</text>
    </view>
  </view>
</view>

